# 🎨 Chill Backend - Variables d'environnement

# Base de données Supabase
DATABASE_URL="postgresql://username:password@host:port/database?schema=public"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# JWT
JWT_SECRET="your-super-secret-jwt-key"
JWT_EXPIRES_IN="7d"

# Serveur
PORT=3000
NODE_ENV="development"

# OpenAPI / reverse proxy (optionnel, prod)
# URL publique du backend sans slash final — ajoute un server dans la spec (Try it out)
PUBLIC_API_URL="https://chill-backend-production.up.railway.app"
# Derrière Railway / proxy : 1 pour faire confiance aux en-têtes X-Forwarded-*
TRUST_PROXY="1"

# CORS
CORS_ORIGIN="http://localhost:19000"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/gif,video/mp4"

# Notifications
FCM_SERVER_KEY="your-fcm-server-key"
